NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# アプリURL (sitemap・OG・メール等で使用)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Anthropic (プロダクトAI用)
ANTHROPIC_API_KEY=

# OpenAI (プロダクトAI用・オプション)
OPENAI_API_KEY=

# Firecrawl (HP取得用)
FIRECRAWL_API_KEY=

# Stripe 課金
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_LIGHTNING=price_...
STRIPE_PRICE_ID_PERSONAL=price_...
STRIPE_PRICE_ID_BUSINESS=price_...

# メール送信 (Resend)
RESEND_API_KEY=re_...

# 問い合わせ通知メール送信先（ADMIN_EMAILS の最初のアドレスを使う場合は不要）
ADMIN_EMAIL=

# Google Analytics (オプション)
NEXT_PUBLIC_GA_ID=G-...

# 管理画面アクセス制御 (カンマ区切りで複数指定可)
ADMIN_EMAILS=your@email.com

# 管理画面 API キー (cast-talk/generate 等で使用・オプション)
ADMIN_SECRET=
CRON_SECRET=

# 管理画面ベーシック認証（PCI DSS 要件。未設定時はスキップ。本番環境では必ず設定する）
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=

# Google Search Console OAuth（GSC連携機能・オプション）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# 自社プロジェクト ID（cast-talk テーマ自動選定 + admin の自社GSC/GA4 表示で使用・オプション）
SELF_PROJECT_ID=

# GA4 プロパティID（admin の今月PV表示用・オプション。数値ID。SELF_PROJECT_ID の GSC OAuth に
# analytics.readonly scope が必要なので、scope 拡張後に再連携してから設定する）
INSIGHT_CAST_GA4_PROPERTY_ID=
